    def run(self):
        # extract the CSRF token from the login page
        self.get_csrf_token()

        # log in to the server to obtain a new cookie and session id
        self.login()

        # add /fakebook/ to the queue to start crawling
        self.queue.append("/fakebook/")
        self.visited_links.add("/fakebook/")

        # keep crawling until there are no more links in the queue
        while self.queue and len(self.secret_flags) < 5:
            link = self.queue.popleft()
            self.crawl(link)

        # once all flags have been found, print them out
        print("Secret flags found:")
        for flag in self.secret_flags:
            print("FLAG: ", flag)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description='crawl Fakebook')
    parser.add_argument('-s', dest="server", type=str, default=DEFAULT_SERVER, help="The server to crawl")
    parser.add_argument('-p', dest="port", type=int, default=DEFAULT_PORT, help="The port to use")
    parser.add_argument('username', type=str, help="The username to use")
    parser.add_argument('password', type=str, help="The password to use")
    args = parser.parse_args()
    sender = Crawler(args)
    sender.run()
